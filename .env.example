# Capybara — function secrets template.
#
# Copy this file to `.env` (which is gitignored — NEVER commit real values) and fill
# in the five values below for ONE instance (one couple = one Supabase project + bot).
# Then set them all at once with the Supabase CLI:
#
#   supabase secrets set --env-file .env --project-ref <your-project-ref>
#
# Or paste them one per row in the Dashboard: Edge Functions -> Secrets -> Add new secret.
#
# These are read in index.ts via Deno.env.get(...). All five must be present before the
# first deploy — in particular ADMIN_TELEGRAM_ID is read once at boot, so deploying
# without it leaves admin commands gated shut (health route reports adminConfigured:false).

# Bot token from @BotFather (looks like 123456789:AA...).
TELEGRAM_BOT_TOKEN=

# Freshly generated per instance. Telegram echoes this back in the
# x-telegram-bot-api-secret-token header; index.ts rejects any update that doesn't match.
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=

# This couple's own Anthropic key (translation, annotation, /recap synthesis).
ANTHROPIC_API_KEY=

# This couple's own OpenAI key (Whisper voice transcription + /recap embeddings).
OPENAI_API_KEY=

# The ENGLISH-NATIVE partner's numeric Telegram ID (the admin). Get it from @userinfobot.
ADMIN_TELEGRAM_ID=

# --- OPTIONAL: one-tap self-deploy via the admin /update command ---
# These power the /update command: it reads the latest BUILD_VERSION from this repo on
# GitHub and, if the live bot is behind, lets the admin redeploy with one tap (it just
# triggers the existing deploy.yml workflow). The feature is INERT if these are unset —
# /update is unavailable to deploy and only reports version status. The five secrets
# above are the only REQUIRED ones; everything below is opt-in.
#
# GitHub PAT used only to dispatch the deploy workflow. Fine-grained token with
# "Actions: write" on this repo (or a classic token with the "workflow" scope).
# Named to avoid colliding with Actions' built-in GITHUB_TOKEN. Leave blank to disable
# the deploy button (the version check still works with just GITHUB_REPO below).
GITHUB_DEPLOY_TOKEN=

# This repo as "owner/name" (e.g. timhagen/capybara-bot). Used for the raw version
# fetch and the workflow dispatch.
GITHUB_REPO=

# Branch the deploy workflow runs against and whose BUILD_VERSION is the "latest".
# Defaults to "main" if unset.
GITHUB_DEPLOY_BRANCH=main

# NOTE: SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected by Supabase at
# runtime — do NOT set them here and do NOT add them as secrets.
